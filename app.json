{
  "expo": {
    "name": "FORGED",
    "slug": "forged",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ForgedLogo.png",
    "scheme": "forged",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#20282A",
        "foregroundImage": "./assets/images/ForgedLogo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.edssurio.forged"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ForgedLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#20282A",
          "image": "./assets/images/ForgedLogo.png",
          "imageWidth": 180,
          "android": {
            "image": "./assets/images/ForgedLogo.png",
            "imageWidth": 180
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d0d46370-ab27-42a2-bdf3-8efe3216ff3b"
      }
    }
  }
}
